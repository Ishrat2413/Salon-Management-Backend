generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Salon {
  id           String       @id @default(uuid())
  name         String
  address      String
  users        User[]
  salonEntries SalonEntry[]
  managerId    String?      @unique
  manager      User?        @relation("SalonManager", fields: [managerId], references: [id])

  @@map("salons")
}

model Service {
  id           String       @id @default(uuid())
  name         String
  salonEntries SalonEntry[]

  @@map("services")
}

model User {
  id                   String          @id @default(uuid())
  fullName             String
  email                String          @unique
  password             String
  role                 Role            @default(EMPLOYEE)
  status               UserStatus      @default(PENDING)
  phoneNumber          String?
  address              String?
  salonId              String?
  salon                Salon?          @relation(fields: [salonId], references: [id])
  managedSalon         Salon?          @relation("SalonManager")
  mainEntries          SalonEntry[]    @relation("MainEmployee")
  splitEntries         SplitEntry[]    @relation("SplitEmployee")
  approvedEntries      SalonEntry[]    @relation("ApprovedBy")
  commissionRate       CommissionRate?
  passwordResetCode    String?
  passwordResetExpires DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@map("users")
}

model CommissionRate {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rate      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("commission_rates")
}

model SalonEntry {
  id            String           @id @default(uuid())
  salonId       String
  salon         Salon            @relation(fields: [salonId], references: [id])
  serviceId     String
  service       Service          @relation(fields: [serviceId], references: [id])
  employeeId    String
  employee      User             @relation("MainEmployee", fields: [employeeId], references: [id])
  clientName    String?
  totalPrice    Int
  actualPrice   Int              @default(0)
  tips          Int?             @default(0)
  addHair       Int?             @default(0)
  commissionRate Int?            @default(0)
  commissionEarnings Float?      @default(0)
  notes         String?
  isSplit       Boolean          @default(false)
  splits        SplitEntry[]
  status        SalonEntryStatus @default(PENDING)
  statusComment String?
  approvedById  String?
  approvedBy    User?            @relation("ApprovedBy", fields: [approvedById], references: [id])

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("salon_entries")
}

model SplitEntry {
  id           String     @id @default(uuid())
  salonEntryId String
  salonEntry   SalonEntry @relation(fields: [salonEntryId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     User       @relation("SplitEmployee", fields: [employeeId], references: [id])
  totalPrice   Int
  tips         Int?       @default(0)
  commissionRate Int?      @default(0)
  commissionEarnings Float?    @default(0)

  @@map("split_entries")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPEND
  REJECTED
}

enum SalonEntryStatus {
  PENDING
  APPROVED
  REJECTED
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Salon {
  id           String       @id @default(uuid())
  name         String
  address      String
  users        User[]
  salonEntries SalonEntry[]

  @@map("salons")
}

model Service {
  id           String       @id @default(uuid())
  name         String
  salonEntries SalonEntry[]

  @@map("services")
}

model User {
  id                   String       @id @default(uuid())
  fullName             String
  email                String       @unique
  password             String
  role                 Role         @default(EMPLOYEE)
  status               UserStatus   @default(PENDING)
  salonId              String?
  salon                Salon?       @relation(fields: [salonId], references: [id])
  mainEntries          SalonEntry[] @relation("MainEmployee")
  splitEntries         SplitEntry[] @relation("SplitEmployee")
  passwordResetCode    String?
  passwordResetExpires DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@map("users")
}

model SalonEntry {
  id         String       @id @default(uuid())
  salonId    String
  salon      Salon        @relation(fields: [salonId], references: [id])
  serviceId  String
  service    Service      @relation(fields: [serviceId], references: [id])
  employeeId String
  employee   User         @relation("MainEmployee", fields: [employeeId], references: [id])
  totalPrice Int
  tips       Int?         @default(0)
  addHair    Int?         @default(0)
  notes      String?
  isSplit    Boolean      @default(false)
  splits     SplitEntry[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("salon_entries")
}

model SplitEntry {
  id           String     @id @default(uuid())
  salonEntryId String
  salonEntry   SalonEntry @relation(fields: [salonEntryId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     User       @relation("SplitEmployee", fields: [employeeId], references: [id])
  totalPrice   Int
  tips         Int?       @default(0)

  @@map("split_entries")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPEND
  REJECTED
}
